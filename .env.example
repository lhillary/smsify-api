# Server (Heroku sets PORT automatically; defaults to 3000 locally)
PORT=3000

# Public URL of this API, no trailing slash — used for Twilio webhooks,
# status callbacks, signature validation, and Swagger docs
BASE_URL=https://smsify-api-c1692787061e.herokuapp.com

# DATABASE
PGUSER=
PGPASSWORD=
PGDATABASE=
PGHOST=
PGPORT=

# JWT
JWT_SECRET=

# Set to "true" to allow new user signups; anything else closes registration
ALLOW_REGISTRATION=false

# TWILIO
# AUTH_TOKEN authenticates Twilio Connect requests on behalf of connected
# accounts and validates webhook signatures; no other app credentials needed
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# OPEN AI
OPENAI_PROJECT_ID=
OPENAI_ORGANIZATION=
OPENAI_API_KEY=